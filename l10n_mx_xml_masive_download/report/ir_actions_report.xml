<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>
   <record id="paperformat_xml_download_sat" model="report.paperformat">
       <field name="name">Paperformat XML SAT Download</field>
       <field name="default" eval="True"/>
       <field name="format">Letter</field>
       <field name="page_height">0</field>
       <field name="page_width">0</field>
       <field name="orientation">Portrait</field>
       <field name="margin_top">10</field>
       <field name="margin_bottom">10</field>
       <field name="margin_left">15</field>
       <field name="margin_right">15</field>
       <field name="header_line" eval="False"/>
       <field name="header_spacing">0</field>
       <field name="dpi">90</field>
   </record>

   <record id="action_report_product_template" model="ir.actions.report">
       <field name="name">Product Report</field>
       <field name="model">account.edi.downloaded.xml.sat</field>
       <field name="report_type">qweb-pdf</field>
       <field name="report_name">l10n_mx_xml_masive_download.report_product</field>
       <field name="report_file">l10n_mx_xml_masive_download.report_product</field>
       <field name="print_report_name">'Factura - %s' % (object.name)</field>
       <field name="binding_model_id" ref="model_account_edi_downloaded_xml_sat"/>
       <field name="binding_type">report</field>
       <field name="paperformat_id" ref="paperformat_xml_download_sat"/>
   </record>
   
</data>
</odoo>