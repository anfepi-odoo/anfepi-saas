<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Modelo Blacklist Art 69-B -->
    <record id="view_art69b_blacklist_list" model="ir.ui.view">
        <field name="name">l10n.mx.art69b.blacklist.list</field>
        <field name="model">l10n_mx.art69b.blacklist</field>
        <field name="arch" type="xml">
            <list string="Lista Negra Art 69-B">
                <field name="rfc"/>
                <field name="razon_social"/>
                <field name="situacion"/>
                <field name="fecha_publicacion"/>
                <field name="numero_publicacion"/>
                <field name="activo"/>
            </list>
        </field>
    </record>
    <record id="view_art69b_blacklist_form" model="ir.ui.view">
        <field name="name">l10n.mx.art69b.blacklist.form</field>
        <field name="model">l10n_mx.art69b.blacklist</field>
        <field name="arch" type="xml">
            <form string="Lista Negra Art 69-B">
                <sheet>
                    <group>
                        <field name="rfc"/>
                        <field name="razon_social"/>
                        <field name="situacion"/>
                        <field name="fecha_publicacion"/>
                        <field name="numero_publicacion"/>
                        <field name="supuesto"/>
                        <field name="activo"/>
                        <field name="fecha_primera_deteccion"/>
                        <field name="fecha_ultima_actualizacion"/>
                        <field name="notas"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Wizard Importación CSV -->
    <record id="view_art69b_import_wizard_form" model="ir.ui.view">
        <field name="name">l10n.mx.art69b.import.wizard.form</field>
        <field name="model">l10n_mx.art69b.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Lista Art 69-B">
                <group>
                    <field name="csv_file" filename="filename"/>
                    <field name="tipo_lista"/>
                </group>
                <footer>
                    <button name="import_csv" type="object" string="Importar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
