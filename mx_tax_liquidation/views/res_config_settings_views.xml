<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================ -->
        <!-- Extensión de Ajustes Contables                                -->
        <!-- ============================================================ -->
        <record id="res_config_settings_view_form_mx_tax" model="ir.ui.view">
            <field name="name">res.config.settings.mx.tax.liquidation</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='account']" position="inside">
                    <block title="Liquidación Fiscal MX" name="mx_tax_liquidation_settings">
                        <setting string="Requerir Acuse SAT"
                                 help="Exige adjuntar el acuse de recibo del SAT antes de marcar la liquidación como Pagada.">
                            <field name="tax_settlement_require_attachment"
                                   widget="boolean_toggle"/>
                        </setting>
                        <setting string="Diario de Liquidaciones Fiscales"
                                 help="Diario contable donde se publicarán los asientos de liquidación fiscal al SAT.">
                            <field name="tax_settlement_journal_id"
                                   options="{'no_create': True}"/>
                        </setting>
                        <setting string="Umbral de Diferencia (%)"
                                 help="Porcentaje máximo de diferencia entre el monto determinado y el monto declarado sin requerir justificación escrita. Por defecto: 5%.">
                            <field name="tax_settlement_diff_threshold"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
