<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_mx_tax_liquidation" model="ir.ui.view">
        <field name="name">res.users.form.mx_tax_liquidation</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <!-- Agrega una sección al final de la pestaña "Derechos de acceso" -->
            <xpath expr="//page[@name='access_rights']" position="inside">
                <group string="Liquidación Fiscal MX" name="group_tax_liquidation_role">
                    <field name="tax_settlement_role" widget="radio" colspan="2"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
