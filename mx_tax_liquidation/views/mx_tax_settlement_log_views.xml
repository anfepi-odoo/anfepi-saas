<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================ -->
        <!-- VISTA LIST — Bitácora de Auditoría                            -->
        <!-- ============================================================ -->
        <record id="view_mx_tax_settlement_log_list" model="ir.ui.view">
            <field name="name">mx.tax.settlement.log.list</field>
            <field name="model">mx.tax.settlement.log</field>
            <field name="arch" type="xml">
                <list string="Bitácora de Auditoría"
                      create="0"
                      edit="0"
                      delete="0"
                      default_order="timestamp desc">
                    <field name="timestamp"/>
                    <field name="settlement_id"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="action"/>
                    <field name="user_id"/>
                    <field name="description"/>
                    <field name="ip_address"/>
                    <field name="payment_id"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- VISTA FORM — Bitácora (solo lectura)                          -->
        <!-- ============================================================ -->
        <record id="view_mx_tax_settlement_log_form" model="ir.ui.view">
            <field name="name">mx.tax.settlement.log.form</field>
            <field name="model">mx.tax.settlement.log</field>
            <field name="arch" type="xml">
                <form string="Entrada de Bitácora" create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="settlement_id" readonly="1"/>
                                <field name="timestamp" readonly="1"/>
                                <field name="action" readonly="1"/>
                                <field name="user_id" readonly="1"/>
                                <field name="ip_address" readonly="1"/>
                            </group>
                            <group>
                                <field name="company_id" readonly="1"/>
                                <field name="payment_id" readonly="1"/>
                            </group>
                        </group>
                        <group string="Descripción">
                            <field name="description" readonly="1" nolabel="1"/>
                        </group>
                        <group string="Valores Antes" invisible="not value_before">
                            <field name="value_before" readonly="1" nolabel="1"/>
                        </group>
                        <group string="Valores Después" invisible="not value_after">
                            <field name="value_after" readonly="1" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- VISTA SEARCH — Bitácora                                       -->
        <!-- ============================================================ -->
        <record id="view_mx_tax_settlement_log_search" model="ir.ui.view">
            <field name="name">mx.tax.settlement.log.search</field>
            <field name="model">mx.tax.settlement.log</field>
            <field name="arch" type="xml">
                <search string="Buscar en Bitácora">
                    <field name="settlement_id"/>
                    <field name="user_id"/>
                    <field name="description"/>
                    <separator/>
                    <filter string="Creaciones" name="create"
                            domain="[('action', '=', 'create')]"/>
                    <filter string="Cálculos" name="calculate"
                            domain="[('action', '=', 'calculate')]"/>
                    <filter string="Confirmaciones" name="confirm"
                            domain="[('action', '=', 'confirm')]"/>
                    <filter string="Pagos" name="pay"
                            domain="[('action', '=', 'pay')]"/>
                    <filter string="Cancelaciones" name="cancel"
                            domain="[('action', '=', 'cancel')]"/>
                    <group>
                        <filter string="Acción" name="group_action"
                                context="{'group_by': 'action'}"/>
                        <filter string="Usuario" name="group_user"
                                context="{'group_by': 'user_id'}"/>
                        <filter string="Liquidación" name="group_settlement"
                                context="{'group_by': 'settlement_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- ACCIÓN — Bitácora de Auditoría                                -->
        <!-- ============================================================ -->
        <record id="action_mx_tax_settlement_log" model="ir.actions.act_window">
            <field name="name">Bitácora de Auditoría Fiscal</field>
            <field name="res_model">mx.tax.settlement.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_mx_tax_settlement_log_search"/>
            <!-- Odoo 19: groups_id eliminado de ir.actions; acceso controlado en menus.xml -->
        </record>
    </data>
</odoo>
